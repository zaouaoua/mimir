# Backend environment (example)
# Copy to .env and fill values.

# Prisma (SQLite) - in Docker we will usually use file:/data/dev.db
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Public URL used inside emails (links)
PUBLIC_BASE_URL="http://localhost:3000"

# Email (optional)
SMTP_REQUIRED="false"  # set to true in production if you want to hard-require SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Luoja back <no-reply@example.com>"

# Optional (only if you use the built-in HTTPS mode that reads letsencrypt files on the host)
# PROTOCOL="HTTP"|"HTTPS"
# DOMAIN="example.com"
